# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True

# ── Hosts / CORS ──────────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ── Database (SQLite for dev; uncomment PostgreSQL for production) ─────────────
# DATABASE_URL=postgresql://interpop:secret@localhost:5432/interpop_db

# ── Media / Static ────────────────────────────────────────────────────────────
MEDIA_ROOT=media

# ── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@interpop.com

# Dev-only: set True to actually send emails via SMTP (uses the credentials above).
# Defaults to False — emails are printed to the runserver console (no real send).
USE_REAL_EMAIL=False
